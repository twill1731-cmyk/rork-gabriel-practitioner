{
  "expo": {
    "name": "Gabriel Practitioner",
    "slug": "gabriel-practitioner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1A14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.gabriel-practitioner",
      "usesNonExemptEncryption": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Gabriel uses your camera to scan supplement labels and barcodes.",
        "NSHealthShareUsageDescription": "Gabriel syncs your health data to provide personalized insights and track your wellness trends.",
        "NSHealthUpdateUsageDescription": "Gabriel syncs your health data to provide personalized insights and track your wellness trends.",
        "NSPhotoLibraryUsageDescription": "Gabriel uses your photo library to upload lab results and supplement images.",
        "NSLocationWhenInUseUsageDescription": "Gabriel uses your location to find naturopathic practitioners near you.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.gabriel_practitioner",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      "expo-camera",
      "expo-location",
      "expo-image-picker",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://rork.com/"
      },
      "eas": {
        "projectId": "b31e8c65-c817-4f67-8c08-a5521fe4f505"
      }
    },
    "owner": "twill1731"
  }
}